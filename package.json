{
  "name": "switch-machine",
  "version": "1.0.3",
  "author": "hebimaoshi",
  "description": "Switch Machine",
  "repository": "https://github.com/zhangqf/node-red-vue",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "sqlite3",
      "@serialport/bindings-cpp",
      "core-js"
    ]
  },
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "generate-icon": "electron-icon-builder --input=./public/ico.png --output=./build",
    "electron:dev": "NODE_ENV=development electron .",
    "electron:build": "vite build && electron-builder --publish never",
    "electron:build:win": "vite build && electron-builder --win --publish never",
    "electron:build:mac": "vite build && electron-builder --mac --publish never",
    "electron:build:linux": "vite build && electron-builder --linux --publish never",
    "electron:build:ci:win": "vite build && electron-builder --win --publish always",
    "electron:build:ci:mac": "vite build && electron-builder --mac --publish always",
    "electron:build:ci:linux": "vite build && electron-builder --linux --publish always"
  },
  "build": {
    "appId": "com.switch-machine.app",
    "productName": "Switch Machine",
    "npmRebuild": true,
    "publish": {
      "provider": "github"
    },
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "icon": "build/icon",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "nr/**/*",
      "build/**/*"
    ],
    "extraResources": [
      {
        "from": "nr",
        "to": "nr"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/win/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/win/icon.ico",
      "uninstallerIcon": "build/win/icon.ico",
      "installerHeaderIcon": "build/win/icon.ico"
    },
    "mac": {
      "target": [
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "build/mac/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "build/png/512x512.png"
    }
  },
  "dependencies": {
    "@flowfuse/node-red-dashboard": "~1.30.2",
    "@stfi/node-red-contrib-mqtt-broker": "~0.5.0",
    "@vueuse/core": "^14.3.0",
    "echarts": "^6.1.0",
    "electron-updater": "^6.8.9",
    "exceljs": "^4.4.0",
    "express": "^4.22.2",
    "mqtt-vue-hook": "^1.2.20",
    "node-red": "^4.1.0",
    "node-red-contrib-crypto-js": "~0.1.1",
    "node-red-contrib-modbus": "~5.45.2",
    "node-red-contrib-uibuilder": "~7.7.3",
    "node-red-contrib-uuid": "~0.0.4",
    "node-red-node-sqlite": "~2.0.1",
    "vue": "^3.5.32",
    "vue-echarts": "^8.0.1",
    "vue-router": "^4.6.4",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/tsconfig": "^0.9.1",
    "electron": "^42.5.1",
    "electron-builder": "^26.15.3",
    "electron-icon-builder": "^2.0.1",
    "esbuild": "^0.28.1",
    "npm-run-all2": "^8.0.4",
    "typescript": "~6.0.0",
    "vite": "^8.0.8",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vue-tsc": "^3.2.6"
  },
  "optionalDependencies": {
    "@node-rs/bcrypt-darwin-arm64": "1.10.7",
    "@node-rs/bcrypt-linux-x64-gnu": "1.10.7",
    "@node-rs/bcrypt-win32-x64-msvc": "1.10.7"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
